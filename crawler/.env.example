# Database Configuration
PGHOST=localhost
PGPORT=5432
PGUSER=stac_user
PGPASSWORD=stac_password
PGDATABASE=stac_db

# Limits
# Types of Endpoints to process (mostly for debugging)
CRAWL_MODE="both"
# Maximum number of root catalogs/APIs to process (mostly for debugging)
MAX_CATALOGS=5
# Maximum number of APIs to process (if mode is 'apis' or 'both')
MAX_APIS=5
# Maximum depth for recursive crawling (0 = root only)
MAX_DEPTH=1024
# Maximum Request retries for not 404 Errors
MAX_REQUEST_RETRIES=5

# Performance
# Request timeout in milliseconds
TIMEOUT_MS=1200000
# Minimum/Maximum number of concurrent requests (Crawlee)
MIN_CONCURRENCY=1
MAX_CONCURRENCY=5

# Target URL
# The starting point for the crawler (usually STAC Index API)
TARGET_URL=https://www.stacindex.org/api/catalogs
